#!/bin/sh
#
# This scenario needs a prober feature that does not exist yet.
#
# The point of it is to send several requests down ONE keepalive connection and
# assert per-response, which is how module context bleeding between requests
# would show. The prober's read loop reads to EOF, so every rule has to ask for
# `Connection: close` -- and a rule that closes the connection is not testing
# keepalive at all. These rules correctly omit it, so each case reads until the
# 5000 ms timeout and reports "does the request ask for Connection: close?".
#
# The missing feature is `pipeline N` with per-response expects, already filed
# as the largest remaining T2 item: it changes a core assumption of the read
# loop, so it is not a small addition. Until then this scenario cannot pass,
# and the failure says nothing about the server under test.
#
# Skipped rather than deleted: these rules are the acceptance test for
# `pipeline N` when it lands, and the scenario should go green the day it does.
echo "needs prober 'pipeline N' with per-response expects; the read loop currently reads to EOF and requires Connection: close"
exit 1
